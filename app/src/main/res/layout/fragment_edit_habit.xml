<?xml version="1.0" encoding="utf-8"?>

<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <variable
            name="habit"
            type="com.example.habittracker.model.Habit" />

        <variable
            name="listener"
            type="com.example.habittracker.view.EditHabitListener" />

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_bg"
        android:orientation="vertical"
        tools:context=".view.EditHabitFragment">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/purple_primary">

        <TextView
            android:id="@+id/headerTitleEdit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="Edit Habit"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/baseline_arrow_back_ios_24"
            app:tint="@color/white" />

        </FrameLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_bg"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:text="Update Habit"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/txtEditHabitName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Habit Name *"
                            android:inputType="text"
                            android:padding="14dp"
                            android:singleLine="true"
                            android:text="@={habit.name}"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/txtEditHabitDesc"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginBottom="14dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:gravity="top|start"
                            android:hint="Short Description *"
                            android:inputType="textMultiLine"
                            android:padding="14dp"
                            android:text="@={habit.description}"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/txtEditGoal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Goal *"
                            android:inputType="number"
                            android:padding="14dp"
                            android:singleLine="true"
                            android:text="@{String.valueOf(habit.goal)}"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_marginBottom="14dp"
                            android:text="How many to complete this task?"
                            android:textColor="@color/gray_text"
                            android:textSize="12sp" />

                        <EditText
                            android:id="@+id/txtEditUnit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:background="@drawable/bg_edittext_outline"
                            android:hint="Unit *"
                            android:inputType="text"
                            android:padding="14dp"
                            android:singleLine="true"
                            android:text="@={habit.unit}"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:layout_marginBottom="14dp"
                            android:text="e.g., glasses, minutes, pages, meals"
                            android:textColor="@color/gray_text"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_edittext_outline"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingStart="14dp"
                                android:paddingTop="8dp"
                                android:text="Select Icon *"
                                android:textColor="@color/gray_text"
                                android:textSize="11sp" />

                            <Spinner
                                android:id="@+id/spinnerEditIcon"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </ScrollView>

        <Button
            android:id="@+id/btnSaveHabit"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_btn_purple_rounded"
            android:onClick="@{listener::onSaveClick}"
            android:text="Save Changes"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</layout>